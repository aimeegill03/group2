# Calculation of monthly SVAR

def calculate_svar(sp500_daily):
    """
    Calculate monthly stock variance (svar) from daily returns data.

    Args:
        sp500_daily (pd.DataFrame): DataFrame with columns ['date', 'ret'] where 'ret' is daily return.

    Returns:
        pd.DataFrame: Monthly stock variance ('svar') with month-end dates.
    """
    # Group by year and month
    sp500_daily['year_month'] = sp500_daily['date'].dt.to_period('M')

    # Calculate monthly variance of returns
    monthly_variance = sp500_daily.groupby('year_month')['ret'].var().reset_index()

    # Rename columns
    monthly_variance = monthly_variance.rename(columns={'year_month': 'date', 'ret': 'svar'})

    # Convert to timestamp and set to end of month
    monthly_variance['date'] = monthly_variance['date'].dt.to_timestamp() + pd.offsets.MonthEnd(0)

    return monthly_variance


