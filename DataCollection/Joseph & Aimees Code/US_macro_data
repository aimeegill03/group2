#BM calculations

def calculate_bm(bm_data):
    wrds = bm_data.copy()

    # Convert necessary columns to numeric
    for col in ['prccq', 'cshoq', 'ceqq']:
        wrds[col] = pd.to_numeric(wrds[col], errors='coerce')

    # Drop rows with missing/invalid values
    wrds = wrds[
        (wrds['prccq'] > 0) & 
        (wrds['cshoq'] > 0) & 
        (wrds['ceqq'] > 0)
    ].copy()

    # Calculate firm-level BM
    wrds['market_equity'] = wrds['prccq'] * wrds['cshoq']
    wrds['bm'] = wrds['ceqq'] / wrds['market_equity']

    # Average across all firms for each date (index-level BM)
    index_bm = wrds.groupby('datadate')['bm'].mean().reset_index()
    index_bm = index_bm.rename(columns={'datadate': 'date'})

    return index_bm


