def load_shiller_data(filepath):
    """
    Load and clean Shiller's dataset, returning price, dividend, and earnings data.

    Args:
        filepath (str): path to the downloaded 'ie_data.xls' file

    Returns:
        pd.DataFrame: Cleaned data with columns ['date', 'price', 'dividend', 'earnings']
    """
    # Load Excel file
    xls = pd.ExcelFile(filepath)

    # Read the correct sheet and skip metadata
    df = pd.read_excel(xls, sheet_name="Data", skiprows=7)

    # Keep only relevant columns
    df = df[['Date', 'P', 'D', 'E']].rename(columns={
        'Date': 'year_month',
        'P': 'price',
        'D': 'dividend',
        'E': 'earnings'
    })

    # Drop rows with missing values
    df = df.dropna(subset=['year_month', 'price', 'dividend', 'earnings'])

    # Convert year_month to datetime format
    df['date'] = pd.to_datetime(
        df['year_month'].astype(str).str.replace('.', '-'),
        format='%Y-%m',
        errors='coerce'
    )

    # Drop any rows where date conversion failed
    df = df.dropna(subset=['date'])

    df['price'] = pd.to_numeric(df['price'], errors='coerce')
    df['dividend'] = pd.to_numeric(df['dividend'], errors='coerce')
    df['earnings'] = pd.to_numeric(df['earnings'], errors='coerce')

    # Return only final useful columns
    return df[['date', 'price', 'dividend', 'earnings']]


