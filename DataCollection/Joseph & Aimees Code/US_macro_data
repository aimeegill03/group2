def get_wrds_macro_data():
    """
    Retrieve macro predictor variables from WRDS:
    - ntis: Net equity issuance (NYSE firms)
    - bm: Book-to-market ratio (NYSE firms)

    Returns:
        dict of pandas DataFrames
    """

    # === Get NYSE permnos first to filter early ===
    nyse_permnos = db.raw_sql("""
        SELECT DISTINCT permno
        FROM crsp.msenames
        WHERE exchcd = 1 AND nameendt >= '1950-01-01'
    """)

    # === ntis: Net equity issuance from CRSP (NYSE only) ===
    crsp_msf = db.raw_sql("""
        SELECT permno, date, prc, shrout
        FROM crsp.msf
        WHERE date >= '1950-01-01'
        ORDER BY date
    """)
    crsp_msf['date'] = pd.to_datetime(crsp_msf['date'])

    crsp_ntis = crsp_msf[crsp_msf['permno'].isin(nyse_permnos['permno'])].copy()

    # === bm: Book-to-market from Compustat (NYSE only) ===
    comp = db.raw_sql("""
        SELECT gvkey, datadate, prccq, cshoq, ceqq, tic
        FROM comp.fundq
        WHERE consol = 'C' AND indfmt = 'INDL' AND datafmt = 'STD'
        AND popsrc = 'D' AND datadate >= '1950-01-01'
        ORDER BY datadate
    """)
    comp['datadate'] = pd.to_datetime(comp['datadate'])

    # === Link Compustat to CRSP using CCM ===
    ccm = db.raw_sql("""
        SELECT gvkey, lpermno AS permno, linkdt, linkenddt
        FROM crsp.ccmxpf_linktable
        WHERE linktype IN ('LU', 'LC') AND usedflag = 1
    """)
    ccm['linkdt'] = pd.to_datetime(ccm['linkdt'])
    ccm['linkenddt'] = pd.to_datetime(ccm['linkenddt']).fillna(pd.Timestamp('today'))

    # Filter CCM to NYSE permnos only
    ccm = ccm[ccm['permno'].isin(nyse_permnos['permno'])]

    # Merge Compustat and CCM
    comp_merged = pd.merge(comp, ccm, on='gvkey', how='inner')
    comp_merged = comp_merged[
        (comp_merged['datadate'] >= comp_merged['linkdt']) &
        (comp_merged['datadate'] <= comp_merged['linkenddt'])
    ]

    return {
        'ntis_data': crsp_ntis,
        'bm_data': comp_merged
    }


