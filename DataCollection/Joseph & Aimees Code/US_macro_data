# NTIS Calculation

def calculate_ntis(crsp_ntis):
    import pandas as pd
    import numpy as np

    df = crsp_ntis.copy()

    # Convert prices and shares to numeric (shares in thousands)
    df['prc'] = pd.to_numeric(df['prc'], errors='coerce')
    df['shrout'] = pd.to_numeric(df['shrout'], errors='coerce')
    df['mcap'] = np.abs(df['prc']) * df['shrout'] / 1000  # millions

    # Keep necessary columns only
    df = df[['permno', 'date', 'mcap']].dropna()

    # Sort by permno/date to compute lagged market cap
    df = df.sort_values(['permno', 'date'])
    df['mcap_lag'] = df.groupby('permno')['mcap'].shift(1)

    # Compute firm-level issuance
    df['issue'] = df['mcap'] - df['mcap_lag']

    # Sum issuance and total market cap by month (cross-section)
    agg = df.groupby('date').agg({
        'issue': 'sum',
        'mcap': 'sum'
    }).dropna()

    # Compute NTIS ratio
    agg['ntis'] = agg['issue'] / agg['mcap']

    return agg[['ntis']].reset_index()


