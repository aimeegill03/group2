def get_fred_data():
    """
    Fetches raw macroeconomic data from FRED:
    - 3-month T-bill (TB3MS)
    - 10-year Treasury bond yield (GS10)
    - BAA and AAA corporate bond yields

    Returns:
        pd.DataFrame: DataFrame with columns ['tbl', 'gs10', 'baa', 'aaa']
    """
    # Your API key
    api_key = 'ad912147425b5950abdde959e8b3931c'
    fred = Fred(api_key=api_key)

    # Define FRED series IDs
    series_ids = {
        'tbl': 'TB3MS',       # 3-month T-Bill rate
        'gs10': 'GS10',       # 10-year Treasury Bond Yield
        'baa': 'BAA',         # BAA corporate bond yield
        'aaa': 'AAA'          # AAA corporate bond yield
    }

    # Fetch the data for each series and store it in a dictionary
    data = {name: fred.get_series(series) for name, series in series_ids.items()}

    # Create a DataFrame from the dictionary of data
    df = pd.DataFrame(data)

    # Reset the index to turn the date index into a column named 'date'
    df.reset_index(inplace=True)
    df.rename(columns={'index': 'date'}, inplace=True) #Rename the index column to 'date'


    # Ensure 'date' is in datetime format
    df['date'] = pd.to_datetime(df['date'])

    # Convert the 'date' column to the end of the month for each row
    df['date'] = df['date'] + pd.offsets.MonthEnd(0)  

    # Print first few rows to confirm the result
    print(df.head())

    return df


