#----------ME Extraction from USA Dataset---------
import pandas as pd

def compute_me_percentiles(input_csv_path, output_csv_path):
    # Read the data
    df = pd.read_csv(input_csv_path, parse_dates=['eom'])
    print("Dataset loaded")
    

    # Check necessary columns exist
    if 'eom' not in df.columns or 'me' not in df.columns:
        raise ValueError("CSV must contain 'eom' and 'me' columns")

    # Group by 'eom' and calculate the percentiles
    result = (
        df.groupby('eom')['me']
        .quantile([0.25, 0.30, 0.35])
        .unstack(level=-1)
        .reset_index()
    )

    # Rename columns for clarity
    result.columns = ['date', 'me_25', 'me_30', 'me_35']

    # Save to CSV
    result.to_csv(output_csv_path, index=False)

