import numpy as np
from sklearn.linear_model import ElasticNet
from sklearn.preprocessing import StandardScaler
from sklearn.model_selection import ParameterGrid
from sklearn.metrics import mean_squared_error
from scipy.stats import spearmanr


# ====================== Configuration ======================
DATA_PATH = r'\Users\607635ap\Downloads\countries_cleaned\countries_cleaned'
RESULTS_PATH = r'\Users\607635ap\Downloads\ENet_Model5'
FACTOR_PATH = r'\Users\607635ap\Downloads\countries_factors_gaps\countries_factors_gaps'
MACRO_PATH = r'\Users\607635ap\Downloads\US_macro_cleaned.csv'

TARGET = 'excess_return_lead_winsorized'

PREDICTORS_BASE = [
    'me_z', 'absacc_z', 'acc_z', 'agr_z', 'bm_z', 'cash_ass_z', 'debt_ass_z', 'cfp_z', 'mom_6m_z', 'pm_z',
    'dolvol_z', 'dy_z', 'egr_z', 'ep_z', 'ill_z', 'mom_12m_z', 'lev_z', 'lgr_z', 'maxret_z', 'rev_1m_z',
    'mom_6m_lag_z', 'pctacc_z', 'retvol_z', 'roe_z', 'sgr_z', 'sales_z', 'price_z', 'turn_z',
    'cashdebt_z', 'chmom_6m_z', 'chpm_z', 'bm_ia_z', 'cfp_ia_z', 'mve_ia_z', 'chpm_ia_z', 'indmom_a_12m_z',
    'stddolvol_z', 'stdturn_z', 'mvel1_z', 'sp_z'
]

AUGMENT_CONFIG = {
    'use_us_factors': True,
    'use_us_gaps': True,
    'use_us_macro': True,
    'use_local_factors': False,
    'use_interactions_us_factors': True,
    'use_interactions_us_gaps': True,
    'use_interactions_local_factors': False
}

def r2_score(y_true, y_pred):
    ss_res = np.sum((y_true - y_pred)**2)
    ss_tot = np.sum(y_true**2)
    return 1 - (ss_res / ss_tot) if ss_tot != 0 else np.nan

def augment_predictors(df, country_code):
    df = df.copy()
    df['date'] = pd.to_datetime(df['date'])
    df.set_index('date', inplace=True)
    new_predictors = [col for col in PREDICTORS_BASE if col in df.columns]

    missing_predictors = [col for col in PREDICTORS_BASE if col not in df.columns]
    print(f"Country {country_code}: Missing {len(missing_predictors)} predictors: {missing_predictors}")

    feature_counts = {
        'base': len(new_predictors),
        'us_factors': 0,
        'us_gaps': 0,
        'us_macro': 0,
        'local_factors': 0,
        'interactions': 0,
    }

    us_factors = pd.DataFrame()
    us_gaps = pd.DataFrame()
    us_macro = pd.DataFrame()

    if AUGMENT_CONFIG['use_us_factors']:
        try:
            print(f"⏳ Loading US factors...")
            us_factors = pd.read_csv(os.path.join(FACTOR_PATH, "USA_factors.csv"), parse_dates=['date']).set_index('date')
            df = df.join(us_factors, how='left')
            new_predictors += list(us_factors.columns)
            feature_counts['us_factors'] = len(us_factors.columns)
            print(f"✅ US factors merged: {list(us_factors.columns)}")
        except FileNotFoundError:
            print(f"⚠ USA_factors.csv not found")

    if AUGMENT_CONFIG['use_us_gaps'] and country_code != "USA":
        try:
            print(f"⏳ Loading US gaps...")
            us_gaps = pd.read_csv(os.path.join(FACTOR_PATH, "USA_gaps.csv"), parse_dates=['date']).set_index('date')
            df = df.join(us_gaps, how='left')
            new_predictors += list(us_gaps.columns)
            feature_counts['us_gaps'] = len(us_gaps.columns)
            print(f"✅ US gaps merged: {list(us_gaps.columns)}")
        except FileNotFoundError:
            print(f"⚠ USA_gaps.csv not found")

    if AUGMENT_CONFIG['use_us_macro']:
        try:
            print(f"⏳ Loading US macro variables...")
            us_macro = pd.read_csv(MACRO_PATH, parse_dates=['date']).set_index('date')  # Changed path handling
            df = df.join(us_macro, how='left')
            new_predictors += list(us_macro.columns)
            feature_counts['us_macro'] = len(us_macro.columns)
            print(f"✅ US macro variables merged: {list(us_macro.columns)}")
        except FileNotFoundError:
                print(f"⚠ US_macro_cleaned.csv not found")

    char_cols = [col for col in new_predictors if col.endswith("_z")]
    interaction_count = 0

    # US factor interactions
    if AUGMENT_CONFIG['use_interactions_us_factors'] and not us_factors.empty:
        print(f"⏳ Creating interactions with US factors...")
        for char in char_cols:
            base = char.replace("_z", "")
            factor_col = f"{base}_factor"
            if factor_col in df.columns:
                interaction_name = f"{char}_x_{factor_col}"
                df[interaction_name] = df[char].fillna(0) * df[factor_col].fillna(0)
                new_predictors.append(interaction_name)
                interaction_count += 1
            else:
                print(f"❌ Missing US factor for base: {base} → expected column: {factor_col}")
        print(f"✅ US factor interactions created")

    # US gap interactions
    if AUGMENT_CONFIG['use_interactions_us_gaps'] and not us_gaps.empty:
        print(f"⏳ Creating interactions with US gaps...")
        for char in char_cols:
            base = char.replace("_z", "")
            gap_col = f"{base}_gap"
            if gap_col in df.columns:
                interaction_name = f"{char}_x_{gap_col}"
                df[interaction_name] = df[char].fillna(0) * df[gap_col].fillna(0)
                new_predictors.append(interaction_name)
                interaction_count += 1
            else:
                print(f"❌ Missing US gap for base: {base} → expected column: {gap_col}")
        print(f"✅ US gap interactions created")

    feature_counts['interactions'] = interaction_count

    df.reset_index(inplace=True)
    df[new_predictors] = df[new_predictors].fillna(0)
    print(f"✅ Predictor augmentation complete — total predictors: {len(new_predictors)}")
    print("\nFeature count summary:")
    for k, v in feature_counts.items():
        print(f"{k.title()}: {v}")
    return df, new_predictors

#---------------------------------------------------------------------
def run_enet_expanding_window(df, predictors, target, country, output_dir,
                              initial_train_ratio=0.3, val_ratio=0.2,
                              param_grid={
                                  'alpha': np.logspace(-3, 3, 10),
                                  'l1_ratio': [0.25, 0.5, 0.75],
                              }):
    df = df.copy()
    df['date'] = pd.to_datetime(df['date'])
    df['year'] = df['date'].dt.year
    df.dropna(subset=predictors + [target], inplace=True)
    df = df.sort_values(by=['id', 'date'])

    years = sorted(df['year'].unique())
    train_years = int(len(years) * initial_train_ratio)
    val_years = max(1, int(len(years) * val_ratio))

    results = []
    metrics_list = []
    oos_r2_list = []
    rank_corrs = []

    for test_start_idx in range(train_years + val_years, len(years)):
        # Window splitting logic
        train_end_year = years[test_start_idx - val_years - 1]
        val_start_year = years[test_start_idx - val_years]
        val_end_year = years[test_start_idx - 1]
        test_year = years[test_start_idx]

        print(f"\nProcessing year {test_year}...")
        print(f"Train <= {train_end_year}, Val: {val_start_year}-{val_end_year}, Test = {test_year}")

        # Data splits
        train_data = df[df['year'] <= train_end_year]
        val_data = df[(df['year'] >= val_start_year) & (df['year'] <= val_end_year)]
        test_data = df[df['year'] == test_year]

        if train_data.empty or val_data.empty or test_data.empty:
            continue

        # Feature scaling
        X_train = train_data[predictors].values
        X_val = val_data[predictors].values
        X_test = test_data[predictors].values
        y_train = train_data[target].values
        y_val = val_data[target].values
        y_test = test_data[target].values

        # Hyperparameter tuning
        best_score = float('inf')
        best_params = None
        best_model = None
        for params in ParameterGrid(param_grid):
            model = ElasticNet(**params, max_iter=10000)
            model.fit(X_train, y_train)
            y_val_pred = model.predict(X_val)
            mse = mean_squared_error(y_val, y_val_pred)
            if mse < best_score:
                best_score, best_params, best_model = mse, params, model

        # Retrain and predict
        best_model.fit(np.vstack([X_train, X_val]), np.hstack([y_train, y_val]))
        y_test_pred = best_model.predict(X_test)

        # Store results
        test_data = test_data.copy()
        test_data['rt_pred'] = y_test_pred
        results.append(test_data[['id', 'date', 'rt_pred', target]])

        # Calculate metrics
        test_mse = mean_squared_error(y_test, y_test_pred)
        test_r2 = r2_score(y_test, y_test_pred)
        metrics_list.append({
            "year": test_year,
            "test_mse": test_mse,
            "test_r2": test_r2,
            "best_params": best_params
        })
        oos_r2_list.append(test_r2)

        # Calculate rank correlation (Spearman's rho)
        if test_data[target].nunique() >= 2:
            rho, _ = spearmanr(test_data['rt_pred'], test_data[target])
            rank_corrs.append(rho)

    # Final outputs
    if results:
        # Save predictions
        final_df = pd.concat(results)
        final_df.to_csv(os.path.join(output_dir, f"{country}_predictions.csv"), index=False)

        # Save performance metrics
        perform_df = pd.DataFrame(metrics_list)
        perform_df.to_csv(os.path.join(output_dir, f"{country}_performance_metrics.csv"), index=False)

        # Calculate strategy metrics
        long_short_returns = []
        decile_spreads = []

        for date, group in final_df.groupby('date'):
            # Long-short returns
            group = group.sort_values('rt_pred')
            n = len(group)
            if n >= 10:
                decile = n // 10
                top = group.iloc[-decile:]
                bottom = group.iloc[:decile]
                long_short_returns.append(top[target].mean() - bottom[target].mean())

            # Decile spreads
            if n >= 10:
                decile_spreads.append(top[target].mean() - bottom[target].mean())

        # Summary metrics
        sharpe_ratio = (np.mean(long_short_returns) / np.std(long_short_returns)) * np.sqrt(12) if long_short_returns else np.nan
        avg_decile_score = np.mean(decile_spreads) if decile_spreads else np.nan
        oos_r2 = np.mean(oos_r2_list) if oos_r2_list else np.nan
        avg_rank_corr = np.nanmean(rank_corrs) if rank_corrs else np.nan

        # Save summary
        summary_df = pd.DataFrame([{
            'country': country,
            'oos_r2': oos_r2,
            'sharpe_ratio': sharpe_ratio,
            'avg_rank_correlation': avg_rank_corr,
            'avg_decile_score_distance': avg_decile_score
        }])
        summary_df.to_csv(os.path.join(output_dir, f"{country}_summary_metrics.csv"), index=False)

    print(f"Finished processing {country}\n{'='*50}")


# ====================== Main Execution ======================
if __name__ == "__main__":
    os.makedirs(RESULTS_PATH, exist_ok=True)

    csv_files = [f for f in os.listdir(DATA_PATH) if f.endswith('.csv')]
    for file in csv_files:
        country_name = file.split('_')[0].upper()
        print(f"\n{'='*50}\nProcessing {country_name}")

        # Load and augment data
        try:
            df = pd.read_csv(os.path.join(DATA_PATH, file))
            print(f"📄 Loaded data shape: {df.shape}")

            df_aug, aug_predictors = augment_predictors(df, country_name)
            print(f"Final predictor count: {len(aug_predictors)}")
            print(f"🚀 Running Elastic Net for {country_name}...")

            # Run model with augmented features
            run_enet_expanding_window(
                df=df_aug,
                predictors=aug_predictors,
                target=TARGET,
                country=country_name,
                output_dir=RESULTS_PATH
            )
        except Exception as e:
            print(f"Failed processing {country_name}: {str(e)}")

    print("All countries processed!")
