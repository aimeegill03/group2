from sklearn.linear_model import ElasticNet
from sklearn.preprocessing import StandardScaler
from sklearn.model_selection import ParameterGrid
from sklearn.metrics import mean_squared_error
from scipy.stats import spearmanr

from google.colab import drive
drive.mount('/content/drive')

DATA_PATH = '/content/drive/MyDrive/.../countries_cleaned'                    #Update this with the correct path to countries_cleaned
RESULTS_PATH = '/content/drive/MyDrive/.../...'                               #Update this with the path to new folder
target = 'excess_return_lead_winsorized'
predictors = [
    'me_z', 'absacc_z', 'acc_z', 'agr_z', 'bm_z', 'cash_ass_z', 'debt_ass_z', 'cfp_z', 'mom_6m_z', 'pm_z',
    'dolvol_z', 'dy_z', 'egr_z', 'ep_z', 'ill_z', 'mom_12m_z', 'lev_z', 'lgr_z', 'maxret_z', 'rev_1m_z',
    'mom_6m_lag_z', 'pctacc_z', 'retvol_z', 'roe_z', 'sgr_z', 'sales_z', 'price_z', 'turn_z',
    'cashdebt_z', 'chmom_6m_z', 'chpm_z', 'bm_ia_z', 'cfp_ia_z', 'mve_ia_z', 'chpm_ia_z', 'indmom_a_12m_z',
    'stddolvol_z', 'stdturn_z', 'mvel1_z', 'sp_z'
]

os.makedirs(RESULTS_PATH, exist_ok=True)

def r2_score(y_true, y_pred):
    """Paper-compliant R² calculation (undemeaned)"""
    ss_res = np.sum((y_true - y_pred)**2)
    ss_tot = np.sum(y_true**2)
    return 1 - (ss_res / ss_tot) if ss_tot != 0 else np.nan

def run_enet_expanding_window(df, predictors, target, country, output_dir,
                              initial_train_ratio=0.3, val_ratio=0.2,
                              param_grid={
                                  'alpha': np.logspace(-3, 3, 20),
                                  'l1_ratio': [0.1, 0.3, 0.5, 0.7, 0.9],
                              }):
    print(f"Starting ElasticNet model for {country}...")

    # Check available predictors
    available_predictors = [col for col in predictors if col in df.columns]
    if not available_predictors:
        print(f"No predictors found for {country}, skipping...")
        return

    # Data preparation
    df = df.copy()
    df['date'] = pd.to_datetime(df['date'])
    df['year'] = df['date'].dt.year
    df[available_predictors] = df[available_predictors].fillna(0)
    df.dropna(subset=available_predictors + [target], inplace=True)
    df = df.sort_values(by=['id', 'date'])

    years = sorted(df['year'].unique())
    train_years = int(len(years) * initial_train_ratio)
    val_years = max(1, int(len(years) * val_ratio))

    results = []
    metrics_list = []
    oos_r2_list = []
    rank_corrs = []

    for test_start_idx in range(train_years + val_years, len(years)):
        # Window splitting logic
        train_end_year = years[test_start_idx - val_years - 1]
        val_start_year = years[test_start_idx - val_years]
        val_end_year = years[test_start_idx - 1]
        test_year = years[test_start_idx]

        # Data splits
        train_data = df[df['year'] <= train_end_year]
        val_data = df[(df['year'] >= val_start_year) & (df['year'] <= val_end_year)]
        test_data = df[df['year'] == test_year]

        if train_data.empty or val_data.empty or test_data.empty:
            continue

        # Feature scaling
        X_train = train_data[available_predictors].values
        X_val = val_data[available_predictors].values
        X_test = test_data[available_predictors].values
        y_train = train_data[target].values
        y_val = val_data[target].values
        y_test = test_data[target].values 
   
        # Hyperparameter tuning
        best_score = float('inf')
        best_params = None
        best_model = None
        for params in ParameterGrid(param_grid):
            model = ElasticNet(**params, max_iter=10000)
            model.fit(X_train, y_train)
            y_val_pred = model.predict(X_val)
            mse = mean_squared_error(y_val, y_val_pred)
            if mse < best_score:
                best_score, best_params, best_model = mse, params, model

        # Retrain and predict
        best_model.fit(np.vstack([X_train, X_val]), np.hstack([y_train, y_val]))
        y_test_pred = best_model.predict(X_test)

        # Store results
        test_data = test_data.copy()
        test_data['rt_pred'] = y_test_pred
        results.append(test_data[['id', 'date', 'rt_pred', target]])

        # Calculate metrics
        test_mse = mean_squared_error(y_test, y_test_pred)
        test_r2 = r2_score(y_test, y_test_pred)
        metrics_list.append({
            "year": test_year,
            "test_mse": test_mse,
            "test_r2": test_r2,
            "best_params": best_params
        })
        oos_r2_list.append(test_r2)

        # Calculate rank correlation (Spearman's rho)
        if test_data[target].nunique() >= 2:
            rho, _ = spearmanr(test_data['rt_pred'], test_data[target])
            rank_corrs.append(rho)

    # Final outputs
    if results:
        # Save predictions
        final_df = pd.concat(results)
        final_df.to_csv(os.path.join(output_dir, f"{country}_predictions.csv"), index=False)

        # Save performance metrics
        perform_df = pd.DataFrame(metrics_list)
        perform_df.to_csv(os.path.join(output_dir, f"{country}_performance_metrics.csv"), index=False)

        # Calculate strategy metrics
        long_short_returns = []
        decile_spreads = []

        for date, group in final_df.groupby('date'):
            # Long-short returns
            group = group.sort_values('rt_pred')
            n = len(group)
            if n >= 10:
                decile = n // 10
                top = group.iloc[-decile:]
                bottom = group.iloc[:decile]
                long_short_returns.append(top[target].mean() - bottom[target].mean())

            # Decile spreads
            if n >= 10:
                decile_spreads.append(top[target].mean() - bottom[target].mean())

        # Summary metrics
        sharpe_ratio = (np.mean(long_short_returns) / np.std(long_short_returns)) * np.sqrt(12) if long_short_returns else np.nan
        avg_decile_score = np.mean(decile_spreads) if decile_spreads else np.nan
        oos_r2 = np.mean(oos_r2_list) if oos_r2_list else np.nan
        avg_rank_corr = np.nanmean(rank_corrs) if rank_corrs else np.nan

        # Save summary
        summary_df = pd.DataFrame([{
            'country': country,
            'oos_r2': oos_r2,
            'sharpe_ratio': sharpe_ratio,
            'avg_rank_correlation': avg_rank_corr,
            'avg_decile_score_distance': avg_decile_score
        }])
        summary_df.to_csv(os.path.join(output_dir, f"{country}_summary_metrics.csv"), index=False)

    print(f"Finished processing {country}\n{'='*50}")

# Process all country files
csv_files = [f for f in os.listdir(DATA_PATH) if f.endswith('.csv')]
for file in csv_files:
    country_name = file.split('_')[0].upper()
    print(f"\n{'='*50}\nProcessing {country_name}")
    df = pd.read_csv(os.path.join(DATA_PATH, file))
    run_enet_expanding_window(df, predictors, target, country_name, RESULTS_PATH)

print("All countries processed!")
