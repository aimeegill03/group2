from collections import defaultdict
import torch
from torch import nn
from torch.utils.data import DataLoader, TensorDataset
import numpy as np

def find_best_lambda_for_country(
    df, predictors,
    hidden_size, lr, batch_size, epochs, patience,
    lambda_grid=[1e-5, 1e-3]
):
    """
    Matches paper logic: expanding training set, 1-year rolling validation set,
    average R² across validation years to select best lambda.
    """

    # Step 1: Preprocess
    #df['returns_next_month'] = df.groupby('id')['returns_winsorized'].shift(-1)
    df['returns_next_month'] = df[TARGET]
    df[predictors] = df[predictors].fillna(0)
    df.dropna(subset=predictors + ['returns_next_month'], inplace=True)
    df['year'] = df['date'].dt.year
    years = sorted(df['year'].unique())
    total_years = len(years)

    # Step 2: Define initial train/val periods
    train_years = int(total_years * 0.3)
    val_years = max(1, int(total_years * 0.2))

    initial_train_end = years[train_years - 1]
    final_val_year = years[train_years + val_years - 1]

    print(f"--> Tuning λ₁ using:")
    print(f"   • Initial Train ≤ {initial_train_end}")
    print(f"   • Shrinking Validation from {years[train_years]} to {final_val_year}")
    print(f"   • Grid: {lambda_grid}\n")

    # Store validation R²s for each lambda
    lambda_r2s = defaultdict(list)

    # Step 3: Shrinking validation years
    for val_year in years[train_years : train_years + val_years]:
        train = df[df['year'] < val_year]
        val = df[df['year'] == val_year]

        if train.empty or val.empty:
            continue

        X_train, y_train = train[predictors].values, train['returns_next_month'].values
        X_val, y_val = val[predictors].values, val['returns_next_month'].values

        print(f"... Validating on {val_year} | Train ≤ {val_year - 1}")

        for lambda1 in lambda_grid:
            # Define model class
            class NN1(nn.Module):
                def __init__(self, input_dim):
                    super().__init__()
                    self.model = nn.Sequential(
                        nn.Linear(input_dim, hidden_size),
                        nn.BatchNorm1d(hidden_size),
                        nn.ReLU(),
                        nn.Linear(hidden_size, 1)
                    )
                def forward(self, x):
                    return self.model(x)

            model = NN1(len(predictors))
            optimizer = torch.optim.Adam(model.parameters(), lr=lr, weight_decay=lambda1)
            criterion = nn.MSELoss()

            train_loader = DataLoader(
                TensorDataset(torch.tensor(X_train, dtype=torch.float32),
                              torch.tensor(y_train, dtype=torch.float32)),
                batch_size=batch_size,
                shuffle=True
            )

            best_val_r2 = -np.inf
            patience_counter = 0

            # Train model with early stopping
            for epoch in range(epochs):
                model.train()
                for xb, yb in train_loader:
                    optimizer.zero_grad()
                    preds = model(xb).squeeze()
                    loss = criterion(preds, yb)
                    loss.backward()
                    optimizer.step()

                model.eval()
                with torch.no_grad():
                    val_pred = model(torch.tensor(X_val, dtype=torch.float32)).squeeze().numpy()
                    ss_res = np.sum((y_val - val_pred) ** 2)
                    ss_tot = np.sum(y_val ** 2)
                    val_r2 = 1 - ss_res / ss_tot

                if val_r2 > best_val_r2:
                    best_val_r2 = val_r2
                    patience_counter = 0
                else:
                    patience_counter += 1
                    if patience_counter >= patience:
                        break

            lambda_r2s[lambda1].append(best_val_r2)
            print(f"   • λ₁ = {lambda1:.0e} → R² = {best_val_r2:.5f}")

    # Step 4: Average R² per lambda
    avg_r2s = {lam: np.nanmean(r2s) for lam, r2s in lambda_r2s.items()}
    best_lambda = max(avg_r2s, key=avg_r2s.get)

    print("\n** Average R² by λ₁:")
    for lam, r2s in avg_r2s.items():
        print(f"   λ₁ = {lam:.0e} → mean R² = {r2s:.5f}")

    print(f"\n🎯 Selected best λ₁: {best_lambda:.0e} (highest average validation R²)\n")
    return best_lambda



'''
**Master Loop to Call Function per Country:**

*With fixed Lambda or optimized Lambda*

'''
# --------- Fixed Lambda Loop -----------
def run_all_countries_fixed_lambda():
    all_weights = []  # ✔ Define this before the loop

    for csv_path in glob(os.path.join(DATA_DIR, "*_cleaned.csv")):
        try:
            df = pd.read_csv(csv_path)
            country = df['country'].iloc[0]
            print(f"\n* Running fixed-lambda model for {country}...")

            country_out = os.path.join(OUTPUT_DIR, f"{country}_results")
            os.makedirs(country_out, exist_ok=True)

            # ⬇ Capture the weight row
            weights_row = run_country_model(
                csv_path,
                output_dir=country_out,
                weight_decay=fixed_lambda
            )

            all_weights.append(weights_row)  # ⬅ Append for later

        except Exception as e:
            print(f"✖ Failed on {csv_path}: {e}")

    # ✔ After the loop, this now works:
    if all_weights:
        merged_weights_df = pd.concat(all_weights, ignore_index=True)
        merged_weights_df.to_csv(os.path.join(OUTPUT_DIR, "all_countries_input_weights.csv"), index=False)
        print("✔ All input weights saved to all_countries_input_weights.csv")
    else:
        print("! No weights were collected.")



# --------- Optimized Lambda Loop -----------

def run_all_countries_with_lambda_optimization():
    for csv_path in glob(os.path.join(DATA_DIR, "*_cleaned.csv")):
        try:
            df = pd.read_csv(csv_path)
            df['date'] = pd.to_datetime(df['date'])
            country = df['country'].iloc[0]
            print(f"\n* Running lambda-optimized model for {country}...")

            country_out = os.path.join(OUTPUT_DIR, f"{country}_results")
            os.makedirs(country_out, exist_ok=True)
            predictors = [col for col in df.columns if col.endswith('_z')]
            best_lambda = find_best_lambda_for_country(
                df.copy(), predictors, hidden_size=NN1_HIDDEN_SIZE,
                lr=lr, batch_size=batch_size, epochs=epochs, patience=patience
            )
            print(f"✔ Best λ₁ for {country}: {best_lambda}")

            run_country_model(
                csv_path,
                output_dir=country_out,
                weight_decay=best_lambda
            )

        except Exception as e:
            print(f"✖ Failed on {csv_path}: {e}")





#-------- merge all the per-country summary_metrics ------- good for making a table later on

def merge_all_summary_metrics(output_dir="./results"):
    summary_files = glob(os.path.join(output_dir, "*_results", "*_summary_metrics.csv"))

    if summary_files:
        all_metrics = pd.concat([pd.read_csv(f) for f in summary_files])
        all_metrics.to_csv(os.path.join(output_dir, "all_countries_metrics.csv"), index=False)
        print("✔ Combined metrics saved to all_countries_metrics.csv")
    else:
        print("! No summary metrics found to merge.")



# ---------- Final Control Switch ----------
# If it's "fixed", we run the NN1 model without tunning lambda
# If it's "tuned", we run the NN1 model with tunning lambda

if __name__ == "__main__":
    mode = "tuned"  # or "fixed" or "tuned"

    if mode == "fixed":
        run_all_countries_fixed_lambda()
    elif mode == "tuned":
        run_all_countries_with_lambda_optimization()
    else:
        print("✖ Invalid mode. Choose 'fixed' or 'tuned'")


    merge_all_summary_metrics()

