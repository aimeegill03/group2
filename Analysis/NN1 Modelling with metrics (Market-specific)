def augment_predictors(
    df,
    country_code,
    base_predictors,
    use_us_factors,
    use_us_gaps,
    use_us_macro,
    use_local_factors,
    use_interactions_us_factors,
    use_interactions_us_gaps,
    use_interactions_local_factors
):
    df['date'] = pd.to_datetime(df['date'])  # ensure datetime
    df.set_index('date', inplace=True)
    new_predictors = list(base_predictors)

    # -------- 1. Local Factors --------
    if use_local_factors:
        path = os.path.join(FACTOR_PATH, f"{country_code}_factors.csv")
        if os.path.exists(path):
            local = pd.read_csv(
                path,
                parse_dates=['date'],
                date_parser=lambda x: pd.to_datetime(x, format="%Y-%m-%d", errors="coerce")
            ).set_index('date')
            df = df.join(local, how='left')
            new_predictors += list(local.columns)
            print(f"✔ Local factors merged for {country_code}")

    # -------- 2. US Factors --------
    if use_us_factors:
        usf = pd.read_csv(
            os.path.join(FACTOR_PATH, "USA_factors.csv"),
            parse_dates=['date'],
            date_parser=lambda x: pd.to_datetime(x, format="%Y-%m-%d", errors="coerce")
        ).set_index('date')
        usf.columns = [f"usf_{col}" for col in usf.columns]
        df = df.join(usf, how='left')
        print("✔ US factors merged")

    # -------- 3. US Macroeconomic Variables --------
    if use_us_macro:
        usm = pd.read_excel(MACRO_PATH, parse_dates=['date'], date_parser=lambda x: pd.to_datetime(x, format="%Y-%m-%d %H:%M:%S"))
        usm.set_index('date', inplace=True)
        usm.columns = [f"usm_{col}" for col in usm.columns]
        df = df.join(usm, how='left')
        new_predictors += list(usm.columns)
        print("✔ US macro variables merged")

    # -------- 4. US Characteristic Gaps (not for USA) --------
    if use_us_gaps and country_code != "USA":
        gaps = pd.read_csv(
            os.path.join(FACTOR_PATH, "USA_gaps.csv"),
            parse_dates=['date'],
            date_parser=lambda x: pd.to_datetime(x, format="%Y-%m-%d", errors="coerce")
        ).set_index('date')

        gaps.columns = [f"gap_{col}" for col in gaps.columns]
        df = df.join(gaps, how='left')
        print("✔ US characteristic gaps merged")

    # Reset index back for modeling
    df.reset_index(inplace=True)

    # -------- Match & Create Interactions (1-to-1 logic) --------
    # US mom with local mom, US value with local value, etc.
    char_cols = [col for col in df.columns if col.endswith("_z")]

    # US Factors interactions
    if use_interactions_us_factors:
        for c in char_cols:
            base = c.replace("_z", "")
            us_col = f"usf_{base}_factor"
            if us_col in df.columns:
                inter = f"{c}_x_{us_col}"
                df[inter] = df[c] * df[us_col]
                new_predictors += [us_col, inter]
        print("✔ Matched interactions with US factors created")

    # US Gaps interactions
    if use_interactions_us_gaps:
        for c in char_cols:
            base = c.replace("_z", "")
            gap_col = f"gap_{base}_gap"
            if gap_col in df.columns:
                inter = f"{c}_x_{gap_col}"
                df[inter] = df[c] * df[gap_col]
                new_predictors += [gap_col, inter]
        print("✔ Matched interactions with US gaps created")

    # Local Factors interactions (only in pooled model)
    if use_interactions_local_factors:
        for c in char_cols:
            base = c.replace("_z", "")
            local_col = f"{base}_factor"
            if local_col in df.columns:
                inter = f"{c}_x_{local_col}"
                df[inter] = df[c] * df[local_col]
                new_predictors += [local_col, inter]
        print("✔ Matched interactions with local factors created")

    return df, new_predictors



############# Function with fixed Lambda
def run_country_model(csv_path, output_dir, predictors=None, hidden_size=NN1_HIDDEN_SIZE, patience=patience, epochs=epochs, weight_decay=fixed_lambda):
    #PREDICTORS = list(PREDICTORS_BASE)  # make a copy so it's not modified globally

    #----------------- Preprocessing --------------------
    df = pd.read_csv(csv_path)
    country = df['country'].iloc[0]
    
    PREDICTORS = [col for col in PREDICTORS_BASE if col in df.columns] # Only keep predictors that actually exist in the current country file
    missing = [col for col in PREDICTORS_BASE if col not in df.columns]
    if missing:
        print(f"! {country} is missing {len(missing)} predictors: {missing}")
    else:
        print(f"✔ {country} has all base predictors.")


    # Augment the dataset if any external data switches are on
    df, PREDICTORS = augment_predictors(
        df,
        country_code=country,
        base_predictors=PREDICTORS,
        use_us_factors=USE_US_FACTORS,
        use_us_gaps=USE_US_GAPS,
        use_us_macro=USE_US_MACRO,
        use_local_factors=USE_LOCAL_FACTORS,
        use_interactions_us_factors=USE_INTERACTIONS_US_FACTORS,
        use_interactions_us_gaps=USE_INTERACTIONS_US_GAPS,
        use_interactions_local_factors=USE_INTERACTIONS_LOCAL_FACTORS
    )

    #country_out = output_dir
    country_out = os.path.join(OUTPUT_DIR, f"{country}_results")
    os.makedirs(country_out, exist_ok=True)

    df['date'] = pd.to_datetime(df['date'])  ## Let pandas auto-detect
    df.sort_values(['id', 'date'], inplace=True)

    # Create next month's return (shifted target)
    #df['returns_next_month'] = df.groupby('id')[TARGET].shift(-1)
    df['returns_next_month'] = df[TARGET]


    # Optional: Fill/impute missing predictor values
    #df[PREDICTORS] = df[PREDICTORS].fillna(0) # or use mean/median

    # Drop only rows where prediction is not possible
    #df.dropna(subset=PREDICTORS + ['returns_next_month'], inplace=True)

    # Add year column for splitting
    df['year'] = df['date'].dt.year

   # Diagnostics
    print("✔ Data shape after cleaning:", df.shape)
    print("✔ Year range:", df['year'].min(), "-", df['year'].max())

    df['date'] = pd.to_datetime(df['date'])  # ensures correct format
    df['year'] = df['date'].dt.year
    years = sorted(df['year'].unique())
    total_years = len(years)
    VALIDATION_YEARS  = max(1, int(total_years * 0.2)) # 20% of available years, at least 1

    print(f"^^ Validation window for {country}: {VALIDATION_YEARS} years out of {total_years}")

    #----------------- Model Definition --------------------
    class NN1(nn.Module):
        def __init__(self, input_dim):
            super().__init__()
            self.model = nn.Sequential(
                nn.Linear(input_dim, NN1_HIDDEN_SIZE),
                nn.BatchNorm1d(NN1_HIDDEN_SIZE),
                nn.ReLU(),
                nn.Linear(NN1_HIDDEN_SIZE, 1)
            )

        def forward(self, x):
            return self.model(x)

    #----------------- Training Function --------------------
    def r2_score(y_true, y_pred):
        ss_res = np.sum((y_true - y_pred)**2)
        ss_tot = np.sum(y_true**2)  # Not centered, to match the paper
        return 1 - ss_res / ss_tot

    def train_model(X_train, y_train, X_val, y_val, X_test, y_test, lr=lr, batch_size=batch_size, epochs=epochs, patience=patience):
        model = NN1(X_train.shape[1])
        optimizer = torch.optim.Adam(model.parameters(), lr=lr, weight_decay=fixed_lambda)
        criterion = nn.MSELoss()

        best_model = None
        best_val_loss = np.inf
        patience_counter = 0

        # Track losses and R2
        train_mse_hist, val_mse_hist, test_mse_hist = [], [], []
        train_r2_hist, val_r2_hist, test_r2_hist = [], [], []

        # Tensors
        X_train_tensor = torch.tensor(X_train, dtype=torch.float32)
        y_train_tensor = torch.tensor(y_train, dtype=torch.float32)
        X_val_tensor = torch.tensor(X_val, dtype=torch.float32)
        y_val_tensor = torch.tensor(y_val, dtype=torch.float32)
        X_test_tensor = torch.tensor(X_test, dtype=torch.float32)
        y_test_tensor = torch.tensor(y_test, dtype=torch.float32)

        train_loader = DataLoader(TensorDataset(X_train_tensor, y_train_tensor), batch_size=batch_size, shuffle=True)

        for epoch in range(epochs):
            model.train()
            for xb, yb in train_loader:
                optimizer.zero_grad()
                preds = model(xb).squeeze()
                loss = criterion(preds, yb)
                loss.backward()
                optimizer.step()

            # Eval on all 3 sets
            model.eval()
            with torch.no_grad():
                train_pred = model(X_train_tensor).squeeze().numpy()
                val_pred = model(X_val_tensor).squeeze().numpy()
                test_pred = model(X_test_tensor).squeeze().numpy()

                train_mse = mean_squared_error(y_train, train_pred)
                val_mse = mean_squared_error(y_val, val_pred)
                test_mse = mean_squared_error(y_test, test_pred)

                train_r2 = r2_score(y_train, train_pred)
                val_r2 = r2_score(y_val, val_pred)
                test_r2 = r2_score(y_test, test_pred)

            train_mse_hist.append(train_mse)
            val_mse_hist.append(val_mse)
            test_mse_hist.append(test_mse)

            train_r2_hist.append(train_r2)
            val_r2_hist.append(val_r2)
            test_r2_hist.append(test_r2)

            if val_mse < best_val_loss:
                best_val_loss = val_mse
                best_model = model.state_dict()
                patience_counter = 0
            else:
                patience_counter += 1
                if patience_counter >= patience:
                    break

        # Reload best model
        model.load_state_dict(best_model)

        return model, (train_mse_hist, val_mse_hist, test_mse_hist), (train_r2_hist, val_r2_hist, test_r2_hist)



############# Expanding for testing, metrics, graphs, etc

    #----------------- Expanding Window Loop --------------------

    results = []
    metrics_list = []


    df['year'] = df['date'].dt.year
    years = sorted(df['year'].unique())
    initial_train_years = int(len(years) * 0.3)
    train_start = years[0]

    for test_start_idx in range(initial_train_years + VALIDATION_YEARS, len(years)):
        train_end_year = years[test_start_idx - VALIDATION_YEARS - 1]
        val_start_year = years[test_start_idx - VALIDATION_YEARS]
        val_end_year = years[test_start_idx - 1]
        test_year = years[test_start_idx]

        print(f"Training: <= {train_end_year}, Validation: {val_start_year}-{val_end_year}, Testing: {test_year}")

        train_data = df[df['year'] <= train_end_year]
        val_data = df[(df['year'] >= val_start_year) & (df['year'] <= val_end_year)]
        test_data = df[df['year'] == test_year]

        if train_data.empty or val_data.empty or test_data.empty:
            continue

        X_train, y_train = train_data[PREDICTORS].values, train_data['returns_next_month'].values
        X_val, y_val = val_data[PREDICTORS].values, val_data['returns_next_month'].values
        X_test = test_data[PREDICTORS].values
        y_test = test_data['returns_next_month'].values


        # Train model with MSE & R² tracking
        model, mse_hist, r2_hist = train_model(X_train, y_train, X_val, y_val, X_test, y_test)

        # Save final values for CSV
        year_metrics = {
            "year": test_year,
            "train_mse": mse_hist[0][-1],
            "val_mse": mse_hist[1][-1],
            "test_mse": mse_hist[2][-1],
            "train_r2": r2_hist[0][-1],
            "val_r2": r2_hist[1][-1],
            "test_r2": r2_hist[2][-1],
            "best_epoch": len(mse_hist[0])
        }
        metrics_list.append(year_metrics)


        # -------- Plotting MSE and R² per epoch --------
        # MSE plot
        plt.figure()
        plt.plot(mse_hist[0], label="Train")
        plt.plot(mse_hist[1], label="Validation")
        plt.plot(mse_hist[2], label="Test")
        plt.yscale("log")
        plt.xlabel("Epoch")
        plt.ylabel("Mean Squared Error")
        plt.title(f"MSE per Epoch ({test_year})")
        plt.legend()
        plt.grid()
        #plt.savefig(f"mse_plot_{test_year}.png")
        plt.savefig(os.path.join(country_out, f"mse_plot_{test_year}.png"))
        plt.close()

        # R² plot
        plt.figure()
        plt.plot(r2_hist[0], label="Train")
        plt.plot(r2_hist[1], label="Validation")
        plt.plot(r2_hist[2], label="Test")
        plt.xlabel("Epoch")
        plt.ylabel("R²")
        plt.title(f"R² per Epoch ({test_year})")
        plt.legend()
        plt.grid()
        #plt.savefig(f"r2_plot_{test_year}.png")
        plt.savefig(os.path.join(country_out, f"r2_plot_{test_year}.png"))
        plt.close()

        # -------- Predict on test set --------
        model.eval()
        with torch.no_grad():
            preds = model(torch.tensor(X_test, dtype=torch.float32)).squeeze().numpy()

        test_data = test_data.copy()
        test_data['nn1_pred'] = preds
        results.append(test_data[['id', 'date', 'nn1_pred', 'returns_next_month']])


    #-------------------------------------------------------------------#
    #----------- Metrics for the country (Calculate and Save) ----------#
    if results:
        final_df = pd.concat(results)

        # Save predictions (needed for calculating metrics)
        # Per stock
        final_df.to_csv(os.path.join(country_out, f"{country}_predictions.csv"), index=False)
        print("✔ Saved predictions to nn1_predictions.csv")

        # Save per-year performance
        perform_df = pd.DataFrame(metrics_list)
        perform_df.to_csv(os.path.join(country_out, f"{country}_performance_metrics.csv"), index=False)
        print(f"✔ Saved per-year metrics to {country}_performance_metrics.csv")

        # Summary metrics
        from scipy.stats import spearmanr
        metrics_dict = {}

        ##----------- Metric 1: Out-of-Sample R² (OOR²) ---------
        # Final Global R² for the Country, once all test-year predictions are concatenated:
        y_true = final_df['returns_next_month'].values
        y_pred = final_df['nn1_pred'].values
        metrics_dict['oor2'] = 1 - np.sum((y_true - y_pred) ** 2) / np.sum(y_true ** 2)
        print(f"✔ Out-of-Sample R²: {metrics_dict['oor2']:.5f}")


        ##----------- Metric 2: Annualized Sharpe Ratio ---------
        #(ranked based on predicted returns, calculated for same portfolio of actual stocks)
        long_short_returns = []
        for date, group in final_df.groupby('date'):
            group = group.sort_values('nn1_pred')
            n = len(group)
            if n < 10: continue
            decile = n // 10
            top = group.iloc[-decile:]
            bottom = group.iloc[:decile]
            long_short_returns.append(top['returns_next_month'].mean() - bottom['returns_next_month'].mean())

        metrics_dict['sharpe_ratio'] = np.mean(long_short_returns) / np.std(long_short_returns) * np.sqrt(12)
        print(f"✔ Annualized Sharpe Ratio: {metrics_dict['sharpe_ratio']:.5f}")


        ##---------- Metric 3: Monthly Rank Correlation ---------
        rank_corrs = []
        for date, group in final_df.groupby('date'):
            if group['returns_next_month'].nunique() < 2: continue
            rho, _ = spearmanr(group['nn1_pred'], group['returns_next_month'])
            rank_corrs.append(rho)

        metrics_dict['avg_rank_correlation'] = np.nanmean(rank_corrs)
        print(f"✔ Average Monthly Rank Correlation: {np.nanmean(rank_corrs):.5f}")


        ##---------- Metric 4: Decile Score Distance ---------
        decile_spreads = []
        for date, group in final_df.groupby('date'):
            group = group.sort_values('nn1_pred')
            n = len(group)
            if n < 10: continue
            decile = n // 10
            top = group.iloc[-decile:]
            bottom = group.iloc[:decile]
            decile_spreads.append(top['returns_next_month'].mean() - bottom['returns_next_month'].mean())

        metrics_dict['avg_decile_score_distance'] = np.mean(decile_spreads)
        print(f"✔ Average Decile Score Distance: {np.mean(decile_spreads):.5f}")

        # Save summary
        metrics_dict['country'] = country
        summary_df = pd.DataFrame([metrics_dict])
        summary_df.to_csv(os.path.join(country_out, f"{country}_summary_metrics.csv"), index=False)
        print(f"✔ Saved summary metrics to {country}_summary_metrics.csv")

    else:
        print(f"! Skipping {country}: No test results available (possibly insufficient data or other filter)")





    # Extract weights from the first layer
    with torch.no_grad():
        input_weights = model.model[0].weight.detach().cpu().numpy()  # shape: (hidden, predictors)
        mean_weights = input_weights.mean(axis=0)  # collapse across neurons

    weight_row = pd.DataFrame([dict(zip(PREDICTORS, mean_weights))])
    weight_row.insert(0, "country", country)
    weight_row.to_csv(os.path.join(country_out, f"{country}_input_weights.csv"), index=False)

    return weight_row  # return for aggregation



