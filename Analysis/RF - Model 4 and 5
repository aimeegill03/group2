def r2_score(y_true, y_pred):
    ss_res = np.sum((y_true - y_pred) ** 2)
    ss_tot = np.sum(y_true ** 2)
    return 1 - ss_res / ss_tot


def run_rf_expanding_window(df, predictors, target, country, output_dir,
                             initial_train_years=0.3, val_years=0.2, test_size=1,
                             param_grid={
                                 'max_depth': [3],
                                 'max_features': [6],
                                 'n_estimators': [300],
                             }):

    print(f"Starting Random Forest model for {country}...")
    os.makedirs(output_dir, exist_ok=True)
    df = df.copy()
    df['date'] = pd.to_datetime(df['date'])
    df['year'] = df['date'].dt.year
    df[predictors] = df[predictors].fillna(0)
    df.dropna(subset=predictors + [target], inplace=True)
    df = df.sort_values(by=['id', 'date'])

    years = sorted(df['year'].unique())
    train_years = int(len(years) * initial_train_years)
    val_years = max(1, int(len(years) * val_years))

    results = []
    metrics_list = []

    test_start_idx = train_years + val_years
    for test_idx in range(test_start_idx, len(years)):
        train_end_year = years[test_idx - val_years - 1]
        test_year = years[test_idx]

        print(f"\nProcessing year {test_year}...")
        print(f"Train <= {train_end_year}, Test = {test_year} (Validation skipped)")

        train_data = df[df['year'] <= train_end_year]
        test_data = df[df['year'] == test_year]

        if train_data.empty or test_data.empty:
            print("Skipping due to insufficient data.")
            continue

        X_train, y_train = train_data[predictors].values, train_data[target].values
        X_test, y_test = test_data[predictors].values, test_data[target].values

        params = {k: v[0] for k, v in param_grid.items()}
        model = RandomForestRegressor(**params, random_state=42)
        model.fit(X_train, y_train)

        y_train_pred = model.predict(X_train)
        y_test_pred = model.predict(X_test)

        train_mse = mean_squared_error(y_train, y_train_pred)
        test_mse = mean_squared_error(y_test, y_test_pred)

        train_r2 = r2_score(y_train, y_train_pred)
        test_r2 = r2_score(y_test, y_test_pred)

        print(f"Year {test_year} | Test MSE: {test_mse:.5f}, Test R²: {test_r2:.5f}")

        metrics_list.append({
            "year": test_year,
            "train_mse": train_mse,
            "val_mse": None,
            "test_mse": test_mse,
            "train_r2": train_r2,
            "val_r2": None,
            "test_r2": test_r2,
            "best_params": params
        })

        test_data = test_data.copy()
        test_data['rf_pred'] = y_test_pred
        results.append(test_data[['id', 'date', 'rf_pred', target]])

    if results:
        print("\nSaving results...")
        final_df = pd.concat(results)
        final_df.to_csv(os.path.join(output_dir, f"{country}_predictions.csv"), index=False)
        perform_df = pd.DataFrame(metrics_list)
        perform_df.to_csv(os.path.join(output_dir, f"{country}_performance_metrics.csv"), index=False)

        metrics_dict = {}
        y_true = final_df[target].values
        y_pred = final_df['rf_pred'].values
        metrics_dict['oor2'] = 1 - np.sum((y_true - y_pred) ** 2) / np.sum(y_true ** 2)

        long_short_returns = []
        for date, group in final_df.groupby('date'):
            group = group.sort_values('rf_pred')
            n = len(group)
            if n < 10: continue
            decile = n // 10
            top = group.iloc[-decile:]
            bottom = group.iloc[:decile]
            long_short_returns.append(top[target].mean() - bottom[target].mean())

        metrics_dict['sharpe_ratio'] = np.mean(long_short_returns) / np.std(long_short_returns) * np.sqrt(12)

        rank_corrs = []
        for date, group in final_df.groupby('date'):
            if group[target].nunique() < 2: continue
            rho, _ = spearmanr(group['rf_pred'], group[target])
            rank_corrs.append(rho)

        metrics_dict['avg_rank_correlation'] = np.nanmean(rank_corrs)

        decile_spreads = []
        for date, group in final_df.groupby('date'):
            group = group.sort_values('rf_pred')
            n = len(group)
            if n < 10: continue
            decile = n // 10
            top = group.iloc[-decile:]
            bottom = group.iloc[:decile]
            decile_spreads.append(top[target].mean() - bottom[target].mean())

        metrics_dict['avg_decile_score_distance'] = np.mean(decile_spreads)
        metrics_dict['country'] = country

        summary_df = pd.DataFrame([metrics_dict])
        summary_df.to_csv(os.path.join(output_dir, f"{country}_summary_metrics.csv"), index=False)
        print("Finished and saved all metrics.")
    else:
        print("No results to save.")

def run_all_random_forests(input_folder, output_folder, target):
    csv_files = glob(os.path.join(input_folder, "*_cleaned.csv"))

    for file_path in csv_files:
        try:
            country_code = os.path.basename(file_path)[:3]
            print(f"\nRunning Random Forest for {country_code}...")
            df = pd.read_csv(file_path)
            excluded_columns = {
                'id', 'country', 'gvkey', 'permno', 'sic', 'ff49', 'exchange',
                'excess_return_winsorized', 'excess_return_lead_winsorized', 'date'
                  }
            predictors = [col for col in df.columns if col not in excluded_columns]
            run_rf_expanding_window(
                df=df,
                predictors=predictors,
                target=target,
                country=country_code,
                output_dir=os.path.join(output_folder, f"{country_code}_rf_results")
            )
        except Exception as e:
            print(f"Failed on {file_path}: {e}")

