# Imports
import os
import pandas as pd
import numpy as np
from glob import glob
from sklearn.linear_model import HuberRegressor
from sklearn.preprocessing import StandardScaler
from scipy.stats import spearmanr

# Defining x Variables
PREDICTORS_BASE = [
    'me_z', 'absacc_z', 'acc_z', 'agr_z', 'bm_z', 'cash_ass_z', 'debt_ass_z',
    'cfp_z', 'mom_6m_z', 'pm_z', 'dolvol_z', 'dy_z', 'egr_z', 'ep_z', 'ill_z',
    'mom_12m_z', 'lev_z', 'lgr_z', 'maxret_z', 'rev_1m_z', 'mom_6m_lag_z',
    'pctacc_z', 'retvol_z', 'roe_z', 'sgr_z', 'sales_z', 'price_z', 'turn_z',
    'cashdebt_z', 'chmom_6m_z', 'chpm_z', 'bm_ia_z', 'cfp_ia_z', 'mve_ia_z',
    'chpm_ia_z', 'indmom_a_12m_z', 'stddolvol_z', 'stdturn_z', 'mvel1_z', 'sp_z'
]


# Defining Huber Function
def run_market_specific_huber(
    df,
    feature_cols,
    target_col,
    market_col='country',
    time_col='date',
    id_col='id',
    output_dir="./OLS_Huber_outputs",
    market_name=None
):
    df = df.copy()
    df[time_col] = pd.to_datetime(df[time_col])
    df['year'] = df[time_col].dt.year
    os.makedirs(output_dir, exist_ok=True)

    results = []
    r2_stats = []

    df_market = df.sort_values(time_col)
    years = sorted(df_market['year'].unique())
    n_years = len(years)
    n_train = int(n_years * 0.3)
    n_val = int(n_years * 0.2)

    print(f"\nMarket: {market_name}")

    for i in range(n_train + n_val, n_years):
        train_years = years[:i - n_val]
        val_years = years[i - n_val:i]
        test_year = years[i]

        train_data = df_market[df_market['year'].isin(train_years)]
        val_data = df_market[df_market['year'].isin(val_years)]
        test_data = df_market[df_market['year'] == test_year]

        train_data = train_data.dropna(subset=feature_cols + [target_col])
        val_data = val_data.dropna(subset=feature_cols + [target_col])
        test_data = test_data.dropna(subset=feature_cols + [target_col])

        if train_data.empty or val_data.empty or test_data.empty:
            print(f"Skipping year {test_year} due to insufficient data.")
            continue

        # Scale features
        scaler = StandardScaler()
        X_train = scaler.fit_transform(train_data[feature_cols].values)
        X_test = scaler.transform(test_data[feature_cols].values)

        y_train = train_data[target_col].values
        y_test = test_data[target_col].values

        model = HuberRegressor(max_iter=1000)
        model.fit(X_train, y_train)

        y_pred = model.predict(X_test)
        r2_oos = 1 - ((y_test - y_pred) ** 2).sum() / (y_test ** 2).sum()

        test_data = test_data.copy()
        test_data['predicted_ret'] = y_pred
        results.append(test_data[[time_col, 'year', id_col, market_col, target_col, 'predicted_ret']])
        r2_stats.append({'market': market_name, 'year': test_year, 'R2_oos': r2_oos})

    if not results:
        print(f"No valid predictions for {market_name}")
        return

    predictions_df = pd.concat(results).sort_values([market_col, time_col, id_col]).reset_index(drop=True)
    predictions_df.to_csv(os.path.join(output_dir, f"{market_name}_predictions.csv"), index=False)

    # Summary Metrics
    y_true = predictions_df[target_col].values
    y_pred = predictions_df['predicted_ret'].values
    oor2 = 1 - np.sum((y_true - y_pred) ** 2) / np.sum(y_true ** 2)

    decile_returns = []
    for date, group in predictions_df.groupby(time_col):
        group = group.sort_values('predicted_ret')
        n = len(group)
        if n < 10: continue
        decile = n // 10
        top = group.iloc[-decile:]
        bottom = group.iloc[:decile]
        decile_returns.append(top[target_col].mean() - bottom[target_col].mean())

    sharpe = np.mean(decile_returns) / np.std(decile_returns) * np.sqrt(12) if len(decile_returns) > 1 else np.nan

    rank_corrs = []
    for date, group in predictions_df.groupby(time_col):
        if group[target_col].nunique() < 2: continue
        rho, _ = spearmanr(group['predicted_ret'], group[target_col])
        rank_corrs.append(rho)

    summary_df = pd.DataFrame([{
        'market': market_name,
        'oor2': oor2,
        'sharpe_ratio': sharpe,
        'avg_rank_correlation': np.nanmean(rank_corrs),
        'avg_decile_score_distance': np.mean(decile_returns)
    }])
    summary_df.to_csv(os.path.join(output_dir, f"{market_name}_summary_metrics.csv"), index=False)
    pd.DataFrame(r2_stats).to_csv(os.path.join(output_dir, f"{market_name}_r2_summary.csv"), index=False)

    print(f"{market_name} completed and saved.")


# Running the Model  --> May need to change paths if running elsewhere
data_dir = "/content/drive/MyDrive/testing_countries"
output_dir = "/content/drive/MyDrive/OLS_Huber_outputs"
target_col = "excess_return_lead_winsorized"

for filepath in glob(os.path.join(data_dir, "*.csv")):
    try:
        df = pd.read_csv(filepath)
        filename = os.path.basename(filepath)
        market_name = filename.split(" ")[-1].split("_")[0]

        available_features = [col for col in PREDICTORS_BASE if col in df.columns]
        missing = [col for col in PREDICTORS_BASE if col not in df.columns]
        if missing:
            print(f"{market_name} is missing {len(missing)} features: {missing}")

        run_market_specific_huber(
            df=df,
            feature_cols=available_features,
            target_col=target_col,
            market_col='country',
            time_col='date',
            id_col='id',
            output_dir=output_dir,
            market_name=market_name
        )

    except Exception as e:
        print(f"Failed for {filepath}: {e}")
