import numpy as np
import pandas as pd
import os
import matplotlib.pyplot as plt
from sklearn.ensemble import GradientBoostingRegressor
from sklearn.metrics import mean_squared_error
from sklearn.model_selection import ParameterGrid
from scipy.stats import spearmanr

def r2_score(y_true, y_pred):
    ss_res = np.sum((y_true - y_pred) ** 2)
    ss_tot = np.sum(y_true ** 2)
    return 1 - ss_res / ss_tot


def run_boosting_expanding_window(df, predictors, target, country, output_dir,
                                   initial_train_years=0.3, val_years=0.2, test_size=1,
                                   param_grid={
                                       'max_depth': [1, 2],
                                       'max_features': [3, 5],
                                       'n_estimators': [100, 500, 1000],
                                       'learning_rate': [0.01, 0.1],
                                   },
                                   verbose_grid=False):

    print(f"Starting boosting model for {country}...")
    os.makedirs(output_dir, exist_ok=True)
    df = df.copy()
    df['date'] = pd.to_datetime(df['date'])
    df['year'] = df['date'].dt.year
    df[predictors] = df[predictors].fillna(0)
    df.dropna(subset=predictors + [target], inplace=True)
    df = df.sort_values(by=['id', 'date'])

    years = sorted(df['year'].unique())
    train_years = int(len(years) * initial_train_years)
    val_years = max(1, int(len(years) * val_years))

    results = []
    metrics_list = []

    for test_start_idx in range(train_years + val_years, len(years)):
        train_end_year = years[test_start_idx - val_years - 1]
        val_start_year = years[test_start_idx - val_years]
        val_end_year = years[test_start_idx - 1]
        test_year = years[test_start_idx]

        print(f"\nProcessing year {test_year}...")
        print(f"Train <= {train_end_year}, Val: {val_start_year}-{val_end_year}, Test = {test_year}")

        train_data = df[df['year'] <= train_end_year]
        val_data = df[(df['year'] >= val_start_year) & (df['year'] <= val_end_year)]
        test_data = df[df['year'] == test_year]

        if train_data.empty or val_data.empty or test_data.empty:
            print("Skipping due to insufficient data.")
            continue

        X_train, y_train = train_data[predictors].values, train_data[target].values
        X_val, y_val = val_data[predictors].values, val_data[target].values
        X_test, y_test = test_data[predictors].values, test_data[target].values

        best_score = float('inf')
        best_params = None
        best_model = None

        print("Starting grid search...")
        for i, params in enumerate(ParameterGrid(param_grid)):
            model = GradientBoostingRegressor(loss='huber', alpha=0.999, **params)
            model.fit(X_train, y_train)
            y_val_pred = model.predict(X_val)
            mse = mean_squared_error(y_val, y_val_pred)

            if verbose_grid:
                print(f"  Params {i+1}/{len(ParameterGrid(param_grid))}: {params} | Validation MSE: {mse:.5f}")

            if mse < best_score:
                best_score = mse
                best_params = params
                best_model = model

        print(f"Best params for {test_year}: {best_params}")

        # Retrain on train+val
        best_model.fit(np.vstack([X_train, X_val]), np.hstack([y_train, y_val]))
        print("Retrained on full training + validation set.")

        y_train_pred = best_model.predict(X_train)
        y_val_pred = best_model.predict(X_val)
        y_test_pred = best_model.predict(X_test)

        # Collect metrics
        train_mse = mean_squared_error(y_train, y_train_pred)
        val_mse = mean_squared_error(y_val, y_val_pred)
        test_mse = mean_squared_error(y_test, y_test_pred)

        train_r2 = r2_score(y_train, y_train_pred)
        val_r2 = r2_score(y_val, y_val_pred)
        test_r2 = r2_score(y_test, y_test_pred)

        print(f"Year {test_year} | Test MSE: {test_mse:.5f}, Test R²: {test_r2:.5f}")

        metrics_list.append({
            "year": test_year,
            "train_mse": train_mse,
            "val_mse": val_mse,
            "test_mse": test_mse,
            "train_r2": train_r2,
            "val_r2": val_r2,
            "test_r2": test_r2,
            "best_params": best_params
        })

        test_data = test_data.copy()
        test_data['rt_pred'] = y_test_pred
        results.append(test_data[['id', 'date', 'rt_pred', target]])

    # Save predictions and metrics
    if results:
        print("\nSaving results...")
        final_df = pd.concat(results)
        final_df.to_csv(os.path.join(output_dir, f"{country}_predictions.csv"), index=False)
        perform_df = pd.DataFrame(metrics_list)
        perform_df.to_csv(os.path.join(output_dir, f"{country}_performance_metrics.csv"), index=False)

        metrics_dict = {}
        y_true = final_df[target].values
        y_pred = final_df['rt_pred'].values
        metrics_dict['oor2'] = 1 - np.sum((y_true - y_pred) ** 2) / np.sum(y_true ** 2)

        long_short_returns = []
        for date, group in final_df.groupby('date'):
            group = group.sort_values('rt_pred')
            n = len(group)
            if n < 10: continue
            decile = n // 10
            top = group.iloc[-decile:]
            bottom = group.iloc[:decile]
            long_short_returns.append(top[target].mean() - bottom[target].mean())

        metrics_dict['sharpe_ratio'] = np.mean(long_short_returns) / np.std(long_short_returns) * np.sqrt(12)

        rank_corrs = []
        for date, group in final_df.groupby('date'):
            if group[target].nunique() < 2: continue
            rho, _ = spearmanr(group['rt_pred'], group[target])
            rank_corrs.append(rho)

        metrics_dict['avg_rank_correlation'] = np.nanmean(rank_corrs)

        decile_spreads = []
        for date, group in final_df.groupby('date'):
            group = group.sort_values('rt_pred')
            n = len(group)
            if n < 10: continue
            decile = n // 10
            top = group.iloc[-decile:]
            bottom = group.iloc[:decile]
            decile_spreads.append(top[target].mean() - bottom[target].mean())

        metrics_dict['avg_decile_score_distance'] = np.mean(decile_spreads)
        metrics_dict['country'] = country

        summary_df = pd.DataFrame([metrics_dict])
        summary_df.to_csv(os.path.join(output_dir, f"{country}_summary_metrics.csv"), index=False)
        print("Finished and saved all metrics.")
    else:
        print("No results to save.")

