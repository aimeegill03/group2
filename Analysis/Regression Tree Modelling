import numpy as np
from sklearn.ensemble import GradientBoostingRegressor
from sklearn.metrics import mean_squared_error
from sklearn.model_selection import ParameterGrid

def run_boosting_annual_retraining_validation(X, y,
                                     train_start=0,
                                     initial_train_size=120,   # e.g. 10 years
                                     val_size=12,              # 12-month validation
                                     test_size=1,              # monthly prediction
                                     param_grid={
                                               'max_depth': [1, 2],
                                               'max_features': [3, 5],
                                               'n_estimators': [100, 500, 1000],
                                               'learning_rate': [0.01, 0.1],
                                           }):

    n_obs = len(y)
    param_grid = list(ParameterGrid(param_grid))
    results = []

    t = train_start + initial_train_size + val_size
    last_train_year = None
    trained_model = None
    best_params = None

    while t + test_size <= n_obs:
        current_year = t // 12  # crude way to define a "year" by month index

        if current_year != last_train_year:
            # Need to retrain
            train_end = t - val_size
            val_end = t

            X_train = X[train_start:train_end]
            y_train = y[train_start:train_end]

            X_val = X[train_end:val_end]
            y_val = y[train_end:val_end]

            best_score = float('inf')
            best_val_pred = None

            for params in param_grid:
                model = GradientBoostingRegressor(
                    loss='huber',
                    alpha=0.999,
                    **params)
                model.fit(X_train, y_train)
                y_pred = model.predict(X_val)
                mse = mean_squared_error(y_val, y_pred)

                if mse < best_score:
                    best_score = mse
                    best_params = params
                    trained_model = model
                    best_val_pred = y_pred.copy()

            # Refit best model on train + val
            trained_model = GradientBoostingRegressor(
                loss='huber',
                alpha=0.999,
                **params)
            trained_model.fit(np.vstack([X_train, X_val]), np.hstack([y_train, y_val]))

            last_train_year = current_year  # mark retraining year

        # Predict on test month
        X_test = X[t:t+test_size]
        y_test = y[t:t+test_size]
        y_test_pred = trained_model.predict(X_test)

        results.append({
            'time': t,
            'retrained': current_year != last_train_year,
            'best_params': best_params,
            'test_mse': mean_squared_error(y_test, y_test_pred),
            'test_true': y_test,
            'test_pred': y_test_pred
        })

        t += test_size

    return results
